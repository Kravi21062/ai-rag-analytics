# ============================================
# AI-Powered RAG Analytics Assistant
# Environment Configuration
# ============================================

# ============================================
# BACKEND CONFIGURATION
# ============================================
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://rag_user:rag_password@db:5432/rag_analytics
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=rag_analytics
DATABASE_USER=rag_user
DATABASE_PASSWORD=rag_password

# ============================================
# JWT AUTHENTICATION
# ============================================
SECRET_KEY=your-super-secret-key-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen:7b
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=/tmp/uploads
ALLOWED_EXTENSIONS=csv,xlsx,xls,pdf
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================
# VECTOR DATABASE CONFIGURATION
# ============================================
VECTOR_DB_PATH=/tmp/faiss_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
MAX_WORKERS=4

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_DIR=/tmp/logs
LOG_FILE=app.log
LOG_FORMAT=json

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# ============================================
# AI MODEL CONFIGURATION
# ============================================
DEFAULT_MODEL=qwen:7b
SUPPORTED_MODELS=qwen:7b,llama2:7b,mistral:7b
FORECAST_METHOD=prophet
ANOMALY_METHOD=isolation_forest

# ============================================
# REPORT GENERATION
# ============================================
REPORT_OUTPUT_DIR=/tmp/reports
REPORT_FORMAT=pdf
REPORT_THEME=professional

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ============================================
# AWS CONFIGURATION (Optional)
# ============================================
AWS_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ============================================
# SENTRY CONFIGURATION (Optional)
# ============================================
SENTRY_ENABLED=false
SENTRY_DSN=

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
